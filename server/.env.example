# Agence — server environment variables
# Copy to .env for local dev. Set these in Render for production.

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# Database (Render provides this automatically for the linked PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname # pragma: allowlist secret

# Alpaca — paper trading only (https://alpaca.markets → Paper Trading → API Keys)
ALPACA_KEY_ID=your-alpaca-key-id
ALPACA_SECRET_KEY=your-alpaca-secret-key

# Plaid — use sandbox keys (https://dashboard.plaid.com → Team Settings → Keys)
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-sandbox-secret
PLAID_ENV=sandbox

# Finnhub — free tier API key (https://finnhub.io → Dashboard → API Key)
FINNHUB_API_KEY=your-finnhub-api-key

# Anthropic — LLM-as-judge (https://console.anthropic.com)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Server port (Render sets this automatically)
PORT=5000
